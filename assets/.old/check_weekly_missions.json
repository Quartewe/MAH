{
  "CheckWeeklyMissions.Entry": {
    "next": [
      "CheckWeeklyMissions.OpenMissionInterface",
      "CheckWeeklyMissions.Select",
      "CheckWeeklyMissions.Back"
    ]
  },
  "CheckWeeklyMissions.OpenMissionInterface": {
    "post_wait_freezes": 1000,
    "recognition": {
      "type": "TemplateMatch",
      "param": {
        "roi": [
          40,
          480,
          100,
          100
        ],
        "template": "missions.png"
      }
    },
    "action": {
      "type": "Click",
      "param": {}
    },
    "next": [
      "CheckWeeklyMissions.Select"
    ]
  },
  "CheckWeeklyMissions.Record": {
    "recognition": {
      "type": "OCR",
      "param": {
        "roi": [
          510,
          170,
          590,
          470
        ],
        "threshold": 0.7
      }
    },
    "action": {
      "type": "Custom",
      "param": {
        "custom_action": "WeeklyMission"
      }
    },
    "next": [
      "CheckWeeklyMissions.Swipe"
    ],
    "on_error": [
      "CheckWeeklyMissions.Stop"
    ]
  },
  "CheckWeeklyMissions.Stop": {
    "next": [
      "Global.GoBackToHomePage"
    ]
  },
  "CheckWeeklyMissions.AllCompleted": {
    "action": {
      "type": "Custom",
      "param": {
        "custom_action": "WeeklyMission"
      }
    },
    "next": [
      "Global.GoBackToHomePage"
    ]
  },
  "CheckWeeklyMissions.Back": {
    "recognition": {
      "type": "OCR",
      "param": {
        "roi": [
          500,
          100,
          300,
          75
        ],
        "expected": "正在进行中的任务"
      }
    },
    "action": {
      "type": "Click",
      "param": {}
    },
    "next": [
      "CheckWeeklyMissions.Back_1"
    ]
  },
  "CheckWeeklyMissions.Select": {
    "recognition": {
