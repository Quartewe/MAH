{
    "NativeADBCommand.Proxy": {
        "action": "Shell",
        "cmd": "settings put global http_proxy 10.0.2.2:7890"
        //"cmd": "settings put global http_proxy 10.0.2.2:${http_proxy_addr}"
    },
    "NativeADBCommand.ClearProxy": {
        "action": "Shell",
        "cmd": "settings put global http_proxy :0"
