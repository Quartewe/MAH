{
    // 本文件为 PI V2 协议示例，更多详情请参考文档
    // https://github.com/MaaXYZ/MaaFramework/blob/main/docs/zh_cn/3.3-ProjectInterfaceV2%E5%8D%8F%E8%AE%AE.md
    "interface_version": 2, // ProjectInterface 协议版本号，当前为 2，固定且必须设置
    "languages": { // 多语言支持配置，键为语言代码，值为对应的翻译文件路径
        "zh_cn": "interface_zh.json",
        "en_us": "interface_en.json",
        "ja_jp": "interface_jp.json",
        "zh_tw": "interface_tw.json"
    },
    "name": "MAH", // 项目唯一标识符，用作项目ID
    "title": "MAH v1.0.0", // 窗口标题，Client直接显示该内容不做修饰。默认使用name和version拼接生成，支持国际化
    "icon": "icon.png", // 应用图标文件路径，相对于项目根目录。未设置时使用默认图标
    "mirrorchyan_rid": "mah", // MirrorChyan资源包标识符，用于资源管理和分发
    "mirrorchyan_multiplatform": true, // 是否支持多平台，影响资源包的打包和分发策略
    "github": "https://github.com/Quartewe/MAH", // 项目GitHub仓库地址，用于版本更新检查和问题反馈
    "version": "1.0.0", // 项目版本号，用于版本更新检查和Client显示
    "contact": "$contact_info", // 联系方式信息，显示在"关于"页面。支持文件路径、URL或直接文本，内容支持Markdown格式，支持国际化
    "license": "MIT", // 项目许可证信息，显示在"关于"页面。支持文件路径、URL或直接文本，内容支持Markdown格式，支持国际化
    "welcome": "$welcome", // 欢迎消息，在用户首次使用时弹窗显示，亦可作为公告使用。支持文件路径、URL或直接文本，内容支持Markdown格式。当内容更新时会再次弹窗，支持国际化
    "description": "$welcome_description", // 项目描述信息，显示在"关于"页面。支持文件路径、URL或直接文本，内容支持Markdown格式，支持国际化
    "agent": {
        "child_exec": "python",
        "child_args": [
            "./agent/main.py" // 子进程参数。支持相对路径（相对于interface.json所在目录）
        ],
        "identifier": "MAH" // 连接标识符，需与 AgentServer.start_up() 中的一致
    },
    "controller": [
        {
            "name": "Android",
            "description": "Connect to Android devices via ADB", // 控制器详细描述。支持文件路径、URL或直接文本，内容支持Markdown格式，支持国际化
            "type": "Adb",
            "display_short_side": 720, // 默认缩放分辨率的短边长度，用于屏幕适配。与long_side二选一
            // "display_long_side": 1080, // 默认缩放分辨率的长边长度，与short_side二选一
            "display_raw": false // 是否使用原始分辨率进行截图，与缩放分辨率设置互斥
        }
    ],
    "resource": [
        {
            "name": "Official_CN",
            "label": "Official CN", // 显示名称，支持国际化。优先显示label，未设置时显示name
            "description": "简中(CHS)", // 资源详细描述。支持文件路径、URL或直接文本，内容支持Markdown格式，支持国际化
            "path": [
                "resource" // 资源路径，相对于interface.json所在目录
            ],
            "controller": [
                "Android"
            ] // 指定该资源包支持的控制器类型列表。若不指定，则支持所有控制器。当用户选择某控制器时，只有支持该控制器的资源包才会显示
        },
        {
            "name": "Official_EN",
            "label": "Official EN",
            "description": "English (ENG)",
            "path": [
                "resource",
                "resource_en"
            ],
            "controller": [
                "Android"
            ]
        },
        {
            "name": "Official_TW",
            "label": "Official TW",
            "description": "繁体中文 (CHT)",
            "path": [
                "resource",
                "resource_tw"
            ],
            "controller": [
                "Android"
            ]
        },
        {
            "name": "Official_JP",
            "label": "Official JP",
            "description": "日本語 (JPN)",
            "path": [
                "resource",
                "resource_jp"
            ],
            "controller": [
                "Android"
            ]
        }
    ],
    "task": [
        {
            "name": "启动游戏",
            "label": "$start_game", // 显示名称，支持国际化。优先显示label，未设置时显示name
            "entry": "Startup.Entry",
            "default_check": true, // 是否默认选中该任务。Client初始化时根据该值决定是否勾选
            "description": "$start_game_description" // 任务详细描述，帮助用户理解任务功能。支持文件路径、URL或直接文本，内容支持Markdown格式，支持国际化
        },
        {
            "name": "检查任务进度",
            "label": "$check_task_progress", // 显示名称，支持国际化。优先显示label，未设置时显示name
            "entry": "CheckWeeklyMissions.Entry",
            "default_check": true, // 是否默认选中该任务。Client初始化时根据该值决定是否勾选
            "description": "$check_task_progress_description", // 任务详细描述，帮助用户理解任务功能。支持文件路径、URL或直接文本，内容支持Markdown格式，支持国际化
            "option": [
                "show_progress"
            ]
        },
        {
            "name": "地城作战",
            "label": "$dungeon_combat", // 显示名称，支持国际化。优先显示label，未设置时显示name
            "default_check": true,
            "description": "$dungeon_combat_description",
            "entry": "Dungeon.Entry",
            "option": [
                "choose_stage_dungeon", // 选项列表，元素为字符串，对应外层option中定义的配置项
                "play_times", // 选项列表，元素为字符串，对应外层option中定义的配置项
                "use_DP_potion",
                "select_team",
                "json_load"
            ]
        },
        {
            "name": "体力作战",
            "label": "$AP_combat", // 显示名称，支持国际化。优先显示label，未设置时显示name
            "default_check": true,
            "description": "$AP_combat_description",
            "entry": "Combat.Entry",
            "option": [
                "choose_stage_AP",
                "play_times",
                "use_AP_potion",
                "select_team",
                "json_load"
            ]
        },
        {
            "name": "领取奖励",
            "label": "$claim_rewards", // 显示名称，支持国际化。优先显示label，未设置时显示name
            "default_check": true,
            "description": "$claim_rewards_description",
            "entry": "Reward.Entry"
        }
    ],
    "option": {
        "show_progress": {
            "type": "show",
            "label": "$current_progress", // 显示名称，支持国际化。优先显示label，未设置时显示name
            "description": "$current_progress_description", // 选项详细描述。支持文件路径、URL或直接文本，内容支持Markdown格式，支持国际化
            "shows": [
                {
                    "name": "当前进度",
                    "label": "$current_progress_show", // 显示名称，支持国际化。优先显示label，未设置时显示name
                    "description": "$current_progress_show_description", // 描述，应支持 文件名、URL、字符串，同时内容支持 markdown，支持国际化
                    "path": "$current_progress_show_path", // 显示内容的数据来源路径，支持从Agent返回的数据中提取显示。路径格式为"{key1.key2...}"，对应数据中的嵌套结构
                    "mode": "auto"
                }
            ]
        },
        "choose_stage_dungeon": {
            "type": "select", // 配置项类型。select为下拉选项框，用户从预定义选项中选择
            "label": "$select_stage", // 显示名称，支持国际化。优先显示label，未设置时显示name
            "description": "$select_stage_description", // 配置项详细描述。支持文件路径、URL或直接文本，内容支持Markdown格式，支持国际化
            // "group": "basic", // 分组标识：basic（基础设置）/ advanced（进阶设置）
            "cases": [
                {
                    "name": "神宿学园旧校舍",
                    "label": "$shinjuku_school", // 显示名称，支持国际化。优先显示label，未设置时显示name
                    "description": "$shinjuku_school_description", // 选项详细描述。支持文件路径、URL或直接文本，内容支持Markdown格式，支持国际化
                    "pipeline_override": {
                        "Dungeon.Change2": {
                            "next": "Dungeon.Shinjuku.Entry"
                        }
                    }
                },
                {
                    "name": "池袋地下大迷宫",
                    "label": "$ikebukuro_dungeon", // 显示名称，支持国际化。优先显示label，未设置时显示name
                    "description": "$ikebukuro_dungeon_description", // 选项详细描述。支持文件路径、URL或直接文本，内容支持Markdown格式，支持国际化
                    "pipeline_override": {
                        "Dungeon.Change2": {
                            "next": "Dungeon.Ikebukuro.Entry"
                        }
                    }
                },
                {
                    "name": "青山陵园地下墓地",
                    "label": "$aoyama_cemetery", // 显示名称，支持国际化。优先显示label，未设置时显示name
                    "description": "$aoyama_cemetery_description", // 选项详细描述。支持文件路径、URL或直接文本，内容支持Markdown格式，支持国际化
                    "pipeline_override": {
                        "Dungeon.Change2": {
                            "next": "Dungeon.Aoyama.Entry"
                        }
                    }
                },
                {
                    "name": "五色结界地下灵场",
                    "label": "$barrier_temple", // 显示名称，支持国际化。优先显示label，未设置时显示name
                    "description": "$barrier_temple_description", // 选项详细描述。支持文件路径、URL或直接文本，内容支持Markdown格式，支持国际化
                    "pipeline_override": {
                        "Dungeon.Change2": {
                            "next": "Dungeon.Barrier.Entry"
                        }
                    }
                },
                {
                    "name": "自定义地城",
                    "label": "$custom_stage", // 显示名称，支持国际化。优先显示label，未设置时显示name
                    "description": "$custom_stage_description", // 选项详细描述。支持文件路径、URL或直接文本，内容支持Markdown格式，支持国际化
                    // 该选项包含子配置项，用户选择该选项后需要进一步输入配置参数才能执行任务
                    "option": [
                        "custom_stage_dungeon"
                    ]
                }
            ]
        },
        "custom_stage_dungeon": {
            "type": "input", // 用户输入类型
            "label": "$custom_stage", // 显示名称，支持国际化。优先显示label，未设置时显示name
            "description": "$custom_stage_description", // 描述，应支持 文件名、URL、字符串，同时内容支持 markdown，支持国际化
            // "group": "basic", // 分组标识
            "inputs": [
                {
                    "name": "自定义关卡",
                    "label": "$custom_stage_input", // 显示名称，支持国际化。优先显示label，未设置时显示name
                    "description": "$custom_stage_input_description", // 描述，应支持 文件名、URL、字符串，同时内容支持 markdown，支持国际化
                    "default": "",
                    "pipeline_type": "string" // 拼接到 pipeline_override 中的类型
                }
            ],
            "pipeline_override": {
                "Dungeon.Change2": {
                    "next": "Dungeon.Activity.Entry"
                },
                "Dungeon.Activity.Choice": {
                    "recognition": {
                        "param": {
                            "expected": "{自定义关卡}"
                        }
                    }
                }
            }
        },
        "play_times": {
            "type": "input",
            // "group": "basic", // 分组标识
            "description": "$play_times_description", // 描述，应支持 文件名、URL、字符串，同时内容支持 markdown，支持国际化
            "inputs": [
                {
                    "name": "挑战次数",
                    "label": "$play_times_input", // 显示名称，支持国际化。优先显示label，未设置时显示name
                    "description": "$play_times_input_description", // 描述，应支持 文件名、URL、字符串，同时内容支持 markdown，支持国际化
                    "default": "999",
                    "pipeline_type": "int", // 拼接到 pipeline_override 中的类型
                    "verify": "^(0|[1-9]\\d*)$"
                }
            ],
            "pipeline_override": {
                "Global.AutoCombat.Count": {
                    "max_hit": "{挑战次数}"
                }
            }
        },
        "use_AP_potion": {
            "type": "input", // switch类型示例
            "label": "$use_AP_potion", // 显示名称，支持国际化。优先显示label，未设置时显示name
            // "group": "basic", // 分组标识
            "description": "$use_AP_potion_description", // 描述，应支持 文件名、URL、字符串，同时内容支持 markdown，支持国际化
            "inputs": [
                {
                    "name": "全体力",
                    "label": "$all_stamina", // 显示名称，支持国际化。优先显示label，未设置时显示name
                    "description": "$all_stamina_description", // 描述，应支持 文件名、URL、字符串，同时内容支持 markdown，支持国际化
                    "default": "0",
                    "pipeline_type": "int", // 拼接到 pipeline_override 中的类型
                    "verify": "^(0|[1-9]\\d*)$"
                },
                {
                    "name": "半体力",
                    "label": "$half_stamina", // 显示名称，支持国际化。优先显示label，未设置时显示name
                    "description": "$half_stamina_description", // 描述，应支持 文件名、URL、字符串，同时内容支持 markdown，支持国际化
                    "default": "0",
                    "pipeline_type": "int", // 拼接到 pipeline_override 中的类型
                    "verify": "^(0|[1-9]\\d*)$"
                },
                {
                    "name": "小体力",
                    "label": "$mini_stamina", // 显示名称，支持国际化。优先显示label，未设置时显示name
                    "description": "$mini_stamina_description", // 描述，应支持 文件名、URL、字符串，同时内容支持 markdown，支持国际化
                    "default": "0",
                    "pipeline_type": "int", // 拼接到 pipeline_override 中的类型
                    "verify": "^(0|[1-9]\\d*)$"
                }
            ],
            "pipeline_override": {
                "Global.AutoCombat.Drink1": {
                    "action": {
                        "param": {
                            "custom_action_param": {
                                "All": "{全体力}",
                                "Half": "{半体力}",
                                "Mini": "{小体力}"
                            }
                        }
                    }
                }
            }
        },
        "use_DP_potion": {
            "type": "input", // switch类型示例
            "label": "$use_DP_potion", // 显示名称，支持国际化。优先显示label，未设置时显示name
            // "group": "basic", // 分组标识
            "description": "$use_DP_potion_description", // 描述，应支持 文件名、URL、字符串，同时内容支持 markdown，支持国际化
            "inputs": [
                {
                    "name": "DP",
                    "label": "$dp_potion", // 显示名称，支持国际化。优先显示label，未设置时显示name
                    "description": "$dp_potion_description", // 描述，应支持 文件名、URL、字符串，同时内容支持 markdown，支持国际化
                    "default": "0",
                    "pipeline_type": "int", // 拼接到 pipeline_override 中的类型
                    "verify": "^(0|[1-9]\\d*)$"
                }
            ],
            "pipeline_override": {
                "Global.AutoCombat.Drink1": {
                    "action": {
                        "param": {
                            "custom_action_param": {
                                "Ranpoil": "{DP}"
                            }
                        }
                    }
                }
            }
        },
        "choose_stage_AP": {
            "type": "select", // 配置项类型。select为下拉选项框，用户从预定义选项中选择
            "label": "$select_stage", // 显示名称，支持国际化。优先显示label，未设置时显示name
            // "group": "basic", // 分组标识
            "description": "$select_stage_description", // 配置项详细描述。支持文件路径、URL或直接文本，内容支持Markdown格式，支持国际化
            "cases": [
                {
                    "name": "14章ATK花本",
                    "label": "$14_atk", // 显示名称，支持国际化。优先显示label，未设置时显示name
                    "description": "$14_atk_description", // 选项详细描述。支持文件路径、URL或直接文本，内容支持Markdown格式，支持国际化
                    "pipeline_override": {
                        "Combat.Entry": {
                            "next": "Flower.Entry"
                        },
                        "Flower.Go1": {
                            "next": "Flower.Select.ATK"
                        }
                    }
                },
                {
                    "name": "14章DEF花本",
                    "label": "$14_def", // 显示名称，支持国际化。优先显示label，未设置时显示name
                    "description": "$14_def_description", // 选项详细描述。支持文件路径、URL或直接文本，内容支持Markdown格式，支持国际化
                    "pipeline_override": {
                        "Combat.Entry": {
                            "next": "Flower.Entry"
                        },
                        "Flower.Go1": {
                            "next": "Flower.Select.DEF"
                        }
                    }
                },
                {
                    "name": "金币n3",
                    "label": "$coin_n3", // 显示名称，支持国际化。优先显示label，未设置时显示name
                    "description": "$coin_n3_description", // 选项详细描述。支持文件路径、URL或直接文本，内容支持Markdown格式，支持国际化
                    "pipeline_override": {
                        "Combat.Entry": {
                            "next": "DailyRes.Entry"
                        },
                        "DailyRes.Go1": {
                            "next": "DailyRes.Coin.Entry"
                        }
                    }
                },
                {
                    "name": "经验n3",
                    "label": "$exp_n3", // 显示名称，支持国际化。优先显示label，未设置时显示name
                    "description": "$exp_n3_description", // 选项详细描述。支持文件路径、URL或直接文本，内容支持Markdown格式，支持国际化
                    "pipeline_override": {
                        "Combat.Entry": {
                            "next": "DailyRes.Entry"
                        },
                        "DailyRes.Go1": {
                            "next": "DailyRes.Exp.Entry"
                        }
                    }
                },
                {
                    "name": "技能n3",
                    "label": "$skill_n3", // 显示名称，支持国际化。优先显示label，未设置时显示name
                    "description": "$skill_n3_description", // 选项详细描述。支持文件路径、URL或直接文本，内容支持Markdown格式，支持国际化
                    "pipeline_override": {
                        "Combat.Entry": {
                            "next": "DailyRes.Entry"
                        },
                        "DailyRes.Go1": {
                            "next": "DailyRes.Skill.Entry"
                        }
                    }
                },
                {
                    "name": "自定义每日任务",
                    "label": "$custom_stage_AP", // 显示名称，支持国际化。优先显示label，未设置时显示name
                    "description": "$custom_stage_AP_description", // 选项详细描述。支持文件路径、URL或直接文本，内容支持Markdown格式，支持国际化
                    // 该选项包含子配置项，用户选择该选项后需要进一步输入配置参数才能执行任务
                    "option": [
                        "custom_stage_AP"
                    ]
                },
                {
                    "name": "活动关卡",
                    "label": "$activity_stage", // 显示名称，支持国际化。优先显示label，未设置时显示name
                    "description": "$activity_stage_description", // 选项详细描述。支持文件路径、URL或直接文本，内容支持Markdown格式，支持国际化
                    // 该选项包含子配置项，用户选择该选项后需要进一步输入配置参数才能执行任务
                    "option": [
                        "custom_stage_Activity"
                    ]
                }
            ]
        },
        "custom_stage_AP": {
            "type": "input",
            "label": "$custom_stage_AP", // 显示名称，支持国际化。优先显示label，未设置时显示name
            "description": "$custom_stage_AP_description", // 描述，应支持 文件名、URL、字符串，同时内容支持 markdown，支持国际化
            // "group": "basic", // 分组标识
            "inputs": [
                {
                    "name": "关卡名称关键词",
                    "label": "$custom_stage_input", // 显示名称，支持国际化。优先显示label，未设置时显示name
                    "description": "$custom_stage_input_description", // 描述，应支持 文件名、URL、字符串，同时内容支持 markdown，支持国际化
                    "default": "",
                    "pipeline_type": "string", // 拼接到 pipeline_override 中的类型
                    "verify": "^(?!\\d+$).+$"
                },
                {
                    "name": "难度关键词",
                    "label": "$difficulty_input",
                    "description": "$difficulty_input_description",
                    "default": "",
                    "pipeline_type": "string",
                    "verify": "^(?!\\d+$).+$"
                }
            ],
            "pipeline_override": {
                "DailyRes.Custom.Entry": {
                    "action": {
                        "param": {
                            "custom_action_param": {
                                "name": "{关卡名称关键词}",
                                "difficulty": "{难度关键词}"
                            }
                        }
                    }
                }
            }
        },
        "custom_stage_Activity": {
            "type": "input",
            // "group": "basic", // 分组标识
            "label": "$custom_stage_activity",
            "description": "$custom_stage_activity_description",
            "inputs": [
                {
                    "name": "兑换物种类",
